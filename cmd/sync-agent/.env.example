# sync-agent — gossip membership node (SWIM via hashicorp/memberlist)

SERVICE_NAME=sync-agent
ENVIRONMENT=development
LOG_LEVEL=info
LOG_FORMAT=json

# Unique node name. Empty → defaults to the hostname.
NODE_ID=

# Gossip listener (UDP + TCP share this port).
GOSSIP_BIND_ADDR=0.0.0.0
GOSSIP_PORT=7070

# What peers should use to reach us. Empty → memberlist auto-detects the
# private IP (correct inside a docker bridge network).
GOSSIP_ADVERTISE_ADDR=
GOSSIP_ADVERTISE_PORT=0

# Comma-separated seed members to join on startup, e.g. "sync-agent-1:7070".
# Leave empty on the first node; it forms a new single-member cluster.
SEEDS=

# Read-only membership API and Prometheus metrics.
HTTP_ADDR=:7072
METRICS_ADDR=:7071

# Sidecar identity advertised to peers via gossip metadata (NodeMeta). When this
# agent runs co-located with a limiter-engine, set ROLE=engine and ENGINE_ADDR to
# that engine's gRPC address so the api-gateway can discover and route to it.
# Leave empty for a plain membership node.
ROLE=
ENGINE_ADDR=

# Engine health-check (only active when ROLE=engine). The sidecar calls the
# engine's gRPC HealthCheck RPC every INTERVAL_MS and advertises healthy=true
# only after the engine answers "ok"; it flips to unhealthy after
# UNHEALTHY_THRESHOLD consecutive failures (gateway then drops it from the ring)
# and back to healthy after HEALTHY_THRESHOLD consecutive successes.
ENGINE_HEALTH_INTERVAL_MS=2000
ENGINE_HEALTH_TIMEOUT_MS=1000
ENGINE_UNHEALTHY_THRESHOLD=3
ENGINE_HEALTHY_THRESHOLD=1
