# ── Shared ────────────────────────────────────────────────────
SERVICE_NAME=api-gateway
ENVIRONMENT=development
LOG_LEVEL=info
LOG_FORMAT=json

# ── api-gateway ───────────────────────────────────────────────
HTTP_ADDR=:8080
METRICS_ADDR=:8090
OTLP_ENDPOINT=localhost:4317        # Jaeger OTLP gRPC; empty disables tracing

# Discovery: the gateway polls a sync-agent's membership API and builds a
# consistent-hash ring from the engine sidecars it advertises (role=engine,
# engine_addr=host:port). No static engine list is needed.
SYNC_AGENT_URL=http://localhost:7072

# Fallback only: used to seed the ring with "localhost:<ENGINE_PORT>" at startup
# before the first successful poll (handy for local single-engine runs).
ENGINE_PORT=9090
