# ── Shared ────────────────────────────────────────────────────
SERVICE_NAME=api-gateway
ENVIRONMENT=development
LOG_LEVEL=info
LOG_FORMAT=json

# ── api-gateway ───────────────────────────────────────────────
HTTP_ADDR=:8080
METRICS_ADDR=:8090
OTLP_ENDPOINT=localhost:4317     # Jaeger OTLP gRPC; empty disables tracing
ENGINE_ADDR=localhost:9090       # limiter-engine gRPC address
