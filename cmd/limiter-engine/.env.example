# ── Shared ────────────────────────────────────────────────────
SERVICE_NAME=limiter-engine
ENVIRONMENT=development
LOG_LEVEL=info
LOG_FORMAT=console

# ── limiter-engine ────────────────────────────────────────────
GRPC_ADDR=:9090
METRICS_ADDR=:9091
OTLP_ENDPOINT=localhost:4317

# Dev mode (docker compose --profile dev up -d):
REDIS_ADDRS=localhost:6379

# Stack mode (docker compose --profile stack up -d) — set this in env, not .env:
# REDIS_ADDRS=redis-1:6379,redis-2:6379,redis-3:6379,redis-4:6379,redis-5:6379,redis-6:6379

LIMITER_DEFAULT_LIMIT=100
LIMITER_DEFAULT_PERIOD_SECS=60
LIMITER_DEFAULT_BURST=10
